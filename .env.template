# Copy this file to .env and fill in your values.
# Then: source .env  (or export each variable before running ./run.sh)

# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional — override defaults
# DEFAULT_MIN_WIN_RATE=60.0
# DEFAULT_MIN_TRANSACTIONS=5
# SCRAPE_LIMIT=50

# Optional — custom RPC endpoints (public endpoints used by default)
# SOL_RPC_URL=https://api.mainnet-beta.solana.com
# ETH_RPC_URL=https://eth.llamarpc.com
# BSC_RPC_URL=https://bsc-dataseed1.binance.org
# BASE_RPC_URL=https://mainnet.base.org

# Optional — custom data/log directories
# DATA_DIR=./data
# LOG_DIR=./logs
